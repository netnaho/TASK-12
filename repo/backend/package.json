{
  "name": "leaseops-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:critical": "vitest run tests/unit/services/security-hardening.test.ts tests/api/privilege-freshness.test.ts tests/unit/middleware/auth.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcrypt": "5.1.1",
    "compression": "1.7.4",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "exceljs": "4.4.0",
    "express": "4.21.1",
    "express-mysql-session": "3.0.3",
    "express-rate-limit": "7.4.1",
    "express-session": "1.18.1",
    "fast-csv": "5.0.1",
    "handlebars": "4.7.8",
    "helmet": "8.0.0",
    "node-cron": "3.0.3",
    "pdfkit": "0.15.0",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.3.0",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/compression": "1.7.5",
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/express-mysql-session": "3.0.6",
    "@types/express-session": "1.18.0",
    "@types/node": "20.17.6",
    "@types/node-cron": "3.0.11",
    "@types/pdfkit": "0.13.5",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@vitest/coverage-v8": "2.1.4",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
