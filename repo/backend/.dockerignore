# Never send these to the Docker build context
node_modules
dist
coverage

# Note: tests/ is intentionally NOT excluded so Dockerfile.test can COPY it.
# The production Dockerfile never COPYs tests, so this adds no bloat there.

# Local environment overrides
.env
.env.*
!.env.example

# Editor / OS
*.log
.DS_Store
.idea
.vscode

# Git
.git
.gitignore
