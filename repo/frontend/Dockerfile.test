# Frontend test image — includes Vitest, Vue Test Utils, jsdom.
FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache bash

COPY package*.json ./
RUN npm ci

COPY index.html vite.config.ts tsconfig.json env.d.ts ./
COPY src ./src
COPY tests ./tests
COPY vitest.config.ts ./vitest.config.ts

CMD ["node", "-v"]
